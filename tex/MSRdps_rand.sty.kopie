\def\makeTextField#1#2{%
  \penalty0%
  \def\MSR@tajenka{#2}%
  \def\tempPolickoName{#1}%
  % \advance\MSR@questions by 1\relax
  \setbox0=\hbox{\,\MSR@tajenka\,}%
  % \ifdim \wd0<\minwidth  \setbox0=\hbox to \minwidth{\hfil\,\MSR@tajenka\,\hfil}\fi
  \begin{ocg}{tajenka}{tajenka}{\viditelnost@tajenky}\hbox to 0 pt{\copy0\hss}\end{ocg}%
  % \expandafter\ifx\csname jmenopolicka:#2\endcsname\relax
  %     \global\advance\Maketextfieldcount by 1
  %     \edef\tempPolickoName{\the\Maketextfieldcount}%
  %     \expandafter\xdef\csname jmenopolicka:#2\endcsname{\the\Maketextfieldcount}%
  % \else
  %     \edef\tempPolickoName{\csname jmenopolicka:#2\endcsname}%
  % \fi
  \raisebox{\dpsyshift}{\makebox[0pt][l]{\makebox[\wd0][c]{%
        \hss}}}%
  %%%%%%%%% Fix to accept more than one command inside \PuzzleAppearance
  \edef\textfieldTmp{\noexpand\textField[\noexpand\BG{gray}\noexpand\S{U}%
    \noexpand\Ff\noexpand\FfReadOnly\the\PuzzleAppearancetoks]%
    {puzzle.\tempPolickoName}{\wd0}{16bp}}\Hy@pdfstringtrue\textfieldTmp}


\newcount\msr@tajenkacount
\newtoks\predtajenkou
\predtajenkou{\color{red}}

\def\msr@user{user}
\newcommand\taj[2][]{%
\write\@auxout{\global\MsrTajenkaStranka=\thepage}%
\leavevmode \def\temp{user#1}%
\ifx\temp\msr@user\global
% Nebyl zadan klic -> posunume pocitadlo policek
\global\advance\msr@tajenkacount by 1\relax\edef\msr@cislotaj{\the\msr@tajenkacount}%
\else
% Byl zadan klic
\expandafter\ifx\csname tajenka:#1\endcsname\relax
% Klic byl zadan poprve -> posuneme pocitadlo a zapamatujeme si cislo do prikazu tajenka:klic
\global\advance\msr@tajenkacount by 1\relax
\edef\msr@cislotaj{\the\msr@tajenkacount}%
\expandafter\xdef\csname tajenka:#1\endcsname{\the\msr@tajenkacount}%
\else
\edef\msr@cislotaj{\csname tajenka:#1\endcsname}%
\fi
\fi
\makeTextField{\msr@cislotaj}{{\the\predtajenkou #2}}%
}


