  \def\MSR@vsechny@odpovedi#1{\lower \zadani@max@hloubka \hbox to 0pt{\msr@pozvednout@box{\pushButton[\A{\JS{processChoice2("\the\dpsAcount","")}}\BG{}\BC{}\S{}\H{O}\CA{}]{odpoved.\the\dpsAcount}{\the\zadani@max@sirka}{\zadani@max@vyska}}\hss}#1}
\fi

