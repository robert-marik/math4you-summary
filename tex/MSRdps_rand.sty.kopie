\begin{insDLJS}[initialize]{matchB}{JS Update of Matching Puzzle B}
app.focusRect = false;

// return a random permutation of a range (similar to randperm in Matlab)
function randperm(maxValue){
  // first generate number sequence
  var permArray = new Array(maxValue);
  for(var i = 0; i < maxValue; i++){
    permArray[i] = i;
  }
  // draw out of the number sequence
  for (var i = (maxValue - 1); i >= 0; --i){
    var randPos = Math.floor((i+1) * Math.random());
    if (randPos > i) {randPos = i;}
    var tmpStore = permArray[i];
    permArray[i] = permArray[randPos];
    permArray[randPos] = tmpStore;
  }
  return permArray;
}


var otazky_perm = new Array();
var tajenka_perm = new Array();
var odpovedi_perm = new Array();

var KonstPocetOdpovedi=\MSRpocetodpovedi;
var KonstPocetOtazek=\MSRpocetotazek;

nahodnyklic = "";

function randperms()
{
  this.resetForm();
  otazky_perm=randperm(\MSRpocetotazek);
  otazky_perm=randperm(\MSRpocetotazek);
  otazky_perm=randperm(\MSRpocetotazek);
  tajenka_perm=randperm(\MSRpocetotazek);
  tajenka_perm=randperm(\MSRpocetotazek);
  tajenka_perm=randperm(\MSRpocetotazek);
  odpovedi_perm=randperm(\MSRpocetodpovedi);  
  odpovedi_perm=randperm(\MSRpocetodpovedi);  
  odpovedi_perm=randperm(\MSRpocetodpovedi);  
  \MSRoptNechatPoradiOtazek
  \MSRoptNechatPoradiOdpovedi
  for (var i = 1; i <= \MSRpocetotazek; i++) { nahodnyklic=nahodnyklic+i+""+najdipozici(otazky_perm[i-1])+", "; }
  nahodnyklic=nahodnyklic.slice(0,-2)+".";
  \MSRoptReseni
  for (var i = 1; i <= \MSRpocetotazek; i++){ zakryjocgZacinajici("q"+i); odkryjocg("q"+i+"-"+(otazky_perm[i-1]+1)); }
  for (var i = 1; i <= \MSRpocetodpovedi; i++){ zakryjocgZacinajici("a"+i); odkryjocg("a"+i+"-"+(odpovedi_perm[i-1]+1));}
  this.dirty=false;
}

function zakryjocg(jmeno)
{
  schovejocg(jmeno);
}

function zakryjocgZacinajici(jmeno)
{
  for(var i=0; aOCGs && i<aOCGs.length;i++) {if((aOCGs[i].name).substring(0,2) == jmeno) schovejocg(aOCGs[i].name); }
}

zakryjocgZacinajici("ta");
zakryjocgZacinajici("OT");
zakryjocgZacinajici("OD");

function najdipozici(prvek)
{
  for (var i = 1; i <= \MSRpocetodpovedi; i++){ if (odpovedi_perm[i-1] == prvek) {return String.fromCharCode(96 + i);}}
  return ("?");
}


randperms();


function processChoice2(fieldname,klic)
{
  clearMessages();
    // Get the question field that corresponds to this question,
    // see if checked.
    //app.alert(odpovedi_perm.join(", ")+"\n"+otazky_perm.join(", ")+"\n\n Otazka "+activeQuestion+" : "+odpovedi_perm[fieldname-1]+" versus "+otazky_perm[activeQuestion-1]+"\n activeQuestion !=nic:"+(activeQuestion != ""));
    var f = this.getField("ckbxQ."+ activeQuestion);
    if ( (activeQuestion != "") && (odpovedi_perm[fieldname-1] == otazky_perm[activeQuestion-1]) ) { // right
        //app.alert("Spravne zodpovezena otazka "+activeQuestion);
        clearRedCrosses ();
        //this.resetForm(["puzzle."+fieldname]);
        pol=this.getField("puzzle."+(tajenka_perm[activeQuestion-1]+1));
        if (pol!=null) {pol.hidden=true;}
        odkryjocg("ta"+(tajenka_perm[activeQuestion-1]+1));
        odkryjocg("OT"+activeQuestion);
        odkryjocg("OD"+fieldname);
        //event.target.textColor = ["RGB", 0, 0.6, 0];
        //f.strokeColor = ["RGB", 0, 0.6, 0];
        f.readonly = true;
        f.hidden = true;
        g=this.getField("otazka."+activeQuestion);
        if (g != null)
        {
          g.readonly=true;
          g.hidden=true;
        }
        g=this.getField("ckbxA."+fieldname);
        g.readonly=true;
        g.hidden=true;
        g=this.getField("odpoved."+fieldname);
        if (g != null)
        {
          g.readonly=true;
          g.hidden=true;
          g.textColor=["RGB", 0, 0, 0];
        }
        checkForFinished(\dspassing,nahodnyklic);
    } else { // wrong
        if ( activeQuestion != "" ) var h = this.getField("ckbxQ."+activeQuestion);
        if ( (activeQuestion=="") || (h.readonly) ) { // active question already answered
            this.getField("ckbxA."+fieldname).value = "Off";
            str = \chooseQ;
            var g = this.getField("report.1");
            if (g!=null)
            {
              g.value = str;
              var to = app.setTimeOut("clearMessages()", 2000);
            }
            else 
            {app.alert(str,3);}
        } else {
            g=this.getField("ckbxA."+fieldname);
            g.style = style.cr;
            g.value = "Yes";
            g.textColor = color.red;
            g.readonly = true;
            g=this.getField("odpoved."+fieldname);
            if (g!=null)
            {
              g.readonly = true;
            }
            ++nMissed;
        }
    }
    this.dirty=false;
}

\end{insDLJS}

