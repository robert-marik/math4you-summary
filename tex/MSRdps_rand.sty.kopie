% Do nasledujicich delkovych registru se sesbira maximalni sirka,
% hloubka a vyska otazek a odpovedi
\newdimen\zadani@max@sirka
\newdimen\zadani@max@vyska
\newdimen\zadani@max@hloubka
\def\vynuluj@rozmery@zadani{\zadani@max@sirka = 0pt \zadani@max@vyska= 0pt \zadani@max@hloubka=0pt}

% Prvni argument se pouzije pro jmeno  boxu ve kterem je ulozeny obsah s druhym argumentem
%
\def\@ulozitbox#1{\@uulozitbox{#1}}
\def\@uulozitbox#1#2{\expandafter\newsavebox\csname mybox:#1\endcsname
   \expandafter\savebox\csname mybox:#1\endcsname{\msr@klic\OdpovedBox{#2}}%
 \expandafter\setbox\expandafter0\expandafter\hbox\expandafter{\expandafter\usebox\csname mybox:#1\endcsname}%
 \ifdim\wd0>\zadani@max@sirka \global\zadani@max@sirka = \wd0\fi
 \ifdim\ht0>\zadani@max@vyska \global\zadani@max@vyska = \ht0\fi
 \ifdim\dp0>\zadani@max@hloubka \global\zadani@max@hloubka = \dp0\fi
}

% Makro pozvedne box tak, aby jeho dolni hrana byla na lince
\def\msr@pozvednout@box#1{\setbox2=\hbox{#1}\raise \dp2 \box2}

% Vystiskne box, ktery je ulozen prikazem \@ulozitbox
\def\@pouzitbox#1{\expandafter\usebox\csname mybox:#1\endcsname}

\def\OT@ulozitbox#1{\OT@uulozitbox{#1}}
\def\OT@uulozitbox#1#2{\expandafter\newsavebox\csname OTmybox:#1\endcsname
   \expandafter\savebox\csname OTmybox:#1\endcsname{\msr@klic\OtazkaBox{#2}}%
 \expandafter\setbox\expandafter0\expandafter\hbox\expandafter{\expandafter\usebox\csname OTmybox:#1\endcsname}%
 \ifdim\wd0>\zadani@max@sirka \global\zadani@max@sirka = \wd0\fi
 \ifdim\ht0>\zadani@max@vyska \global\zadani@max@vyska = \ht0\fi
 \ifdim\dp0>\zadani@max@hloubka \global\zadani@max@hloubka = \dp0\fi
}
\def\OT@pouzitbox#1{\expandafter\usebox\csname OTmybox:#1\endcsname}

\def\OtazkaBox#1{\hbox{#1}}
\def\OdpovedBox#1{\hbox{#1}}

\def\MSRotazka#1{\OT@pouzitbox{#1}}
\def\MSRodpoved#1{\@pouzitbox{#1}}

