% Rozmery stranky

% Rozmery stranky si ulozime
\newdimen\msr@savepaperwidth
\msr@savepaperwidth=\paperwidth
\newdimen\msr@savepaperheight
\msr@savepaperheight=\paperheight

% Pokud se pouzilo \PassOptionsToPackage na balicek geometry (zmenil
% se aspon jeden rozmer papiru), nedelame nic. Jinak pouzijeme nastave
% rozmery, pripadne vynasobene parametrem scalepage.
\RequirePackage{geometry}
\ifdim \msr@savepaperwidth=\paperwidth
\ifdim \msr@savepaperheight=\paperheight

\def\msr@scalepaper{1}

\ifx\msr@scalepaper\undefined
\def\msr@scalepaper{1}
\geometry{paperwidth=6.5in, paperheight=4.6in,margin=12pt, top=24pt, bottom=1.4cm}
% paperheight zmenseno ze 4.875 na 4.5, kvuli aspect/ratio podkladu od grafika. RM 17.5.2018
% 15.24cm krat 12.38cm, pomer 4:3
\else
\newdimen\msr@xrozmer \msr@xrozmer=6.5in \msr@xrozmer=\msr@scalepaper \msr@xrozmer
\newdimen\msr@yrozmer \msr@yrozmer=4.875in \msr@yrozmer=\msr@scalepaper \msr@yrozmer
\geometry{paperwidth={\the\msr@xrozmer}, paperheight={\the\msr@yrozmer},margin=12pt, top=12pt, bottom=1.4cm}
\fi

\fi\fi %ifdim

