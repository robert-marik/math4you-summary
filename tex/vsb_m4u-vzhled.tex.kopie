\newdimen\msr@posun@ikonekC
\msr@posun@ikonekC=10.65cm

\def\ikonkyA{% V parovacich hrach
\AtPageLowerLeft{\hbox to 0 pt{\kern \msr@scalepaper\msr@posun@ikonekB%
 \raise 2pt \hbox to 0 pt{\hskip \msr@ikony@a@dimen 
 \hskip -4pt
 \msr@jedno@tlacitko{\MsrCustomFullscreen}{fullscreen}%
 \msr@jedno@tlacitko{\Acrobatmenu{NextPage}}{next}%
 \hss}\hss
}\global\def\ikonky{\ikonkyB}
}%
}


\definecolor{ramecekokraj}{RGB}{153,163,97}
\definecolor{ramecekvnitrek}{RGB}{189,204,97}

\tikzset{newnode/.style={inner sep=0.9mm, line width=2pt, rounded corners=5pt}}


\def\logo@obalka#1{
% \begin{tikzpicture}
%   \fill[ramecekvnitrek, rounded corners=5pt] (0,0)--(0,0.8cm)--(\MsrPocetKrokuB*1.6em+0.8em,0.8cm)--(\MsrPocetKrokuB*1.6em+0.8em,0);
%   \draw[ramecekokraj, line width=2pt, rounded corners=5pt] (0,0)--(0,0.8)--(\MsrPocetKrokuB*1.6em+0.8em,0.8)--(\MsrPocetKrokuB*1.6em+0.8em,0);
% \end{tikzpicture}
\begin{tikzpicture}
    \node[newnode] (znacky) {#1};
    \draw[draw=ramecekokraj, rounded corners=8pt, line width=2pt, fill=ramecekvnitrek]  ($(znacky.south west)+(0mm,0mm)$) 
                -- ($(znacky.north west)+(0mm,-0.5mm)$)
                -- ($(znacky.north east)+(0mm,-0.5mm)$)
                -- ($(znacky.south east)+(0mm,0mm)$);
    \node[newnode] (znacky) {#1};
\end{tikzpicture}
}%

