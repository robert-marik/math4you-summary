% Ikonky 
\def\msr@jedno@tlacitko#1{%
#1{%\hbox to 0 pt{\vrule height 1 cm\hss}%
\hbox{\vrule height 0.8cm depth -0.1cm width 0 pt
\hskip  0.051\paperwidth 
\vrule height 0.8cm depth -0.1cm width 0 pt}%
%\hbox to 0 pt{\vrule height 1 cm\hss}%
}\hskip 0.0052\paperwidth}

\newdimen\msr@ikonka@vyska
\msr@ikonka@vyska=0.88cm
%\def\msr@jedno@tlacitko#1#2{#1{\includegraphics[height=\msr@scalepaper\msr@ikonka@vyska]{msr_#2.png}}\hskip \msr@ikony@c@dimen} %
%\def\msr@jedno@tlacitko#1#2{#1{\raise 3pt\hbox to 0 pt{\vrule height 16pt depth -2pt width 0 pt\hss}\hskip 0.037\paperwidth}\hskip \msr@ikony@c@dimen}%

\def\msr@jedno@tlacitko#1#2{#1{\includegraphics[height=%\msr@scalepaper
\msr@ikonka@vyska]{m4u_Icon_#2.pdf}}\hskip \msr@ikony@c@dimen} %

\newbox\fullscreenBox

\def\MsrCustomFullscreen#1{\setbox\fullscreenBox\hbox{#1}%
\raise 6pt \hbox to 0 pt{\pushButton[\S{}\H{N}\BG{}\BC{}\A{\JS{CustomFullscreen();}}]{MsrcustomFullscreen}{\wd\fullscreenBox}{\ht\fullscreenBox}\hss}%
\box\fullscreenBox
}

%\def\MsrCustomFullscreen#1#2{}

\def\msr@ikony@a@dimen{0.03\paperwidth} % mezera na zacatku
\def\msr@ikony@a@dimen{0.01\paperwidth} % mezera na zacatku
\def\msr@ikony@b@dimen{0.002\paperwidth} % mezera za domeckem
\def\msr@ikony@c@dimen{8pt} % mezera mezi ikonkama

\def\ikonky{%
\AtPageLowerLeft{\hbox to 0 pt{\kern 10.5cm%
% \hskip 0.53\paperwidth
% %\hbox to 0 pt{\includegraphics[width=0.45\paperwidth]{msr_ikony_pozadi.png}\hss}%
 \raise 12pt \hbox to 0 pt{\hskip \msr@ikony@a@dimen 
 \msr@jedno@tlacitko{\Acrobatmenu{PrevPage}}{Back}%
 \msr@jedno@tlacitko{\MsrCustomFullscreen}{Screen}%
 \msr@jedno@tlacitko@next
 \msr@jedno@tlacitko{\Acrobatmenu{FirstPage}}{Home}%
 %\msr@jedno@tlacitko{\hyperlink{zacatek}}{first}%
 %\msr@jedno@tlacitko{\Acrobatmenu{GoBack}}{back}%
 %\msr@jedno@tlacitko{\Acrobatmenu{LastPage}}{last}%
 \hss}\hss
}%\dal@bez@ikon%
}%
}

\def\msr@jedno@tlacitko@next{\msr@jedno@tlacitko{\Acrobatmenu{NextPage}}{Next}}


