\def\msr@polozka#1#2{\expandafter\def\csname autor #2\endcsname{\csname autor #1\endcsname}}
%\input msr_autori.tex

\def\msr@polozka#1#2{%
\expandafter\def\csname oblast:#2\endcsname{#1}
\expandafter\def\csname oblast:#1\endcsname{#1}
}
\input msr_oblasti.tex

\def\msr@polozka#1#2#3{%
\expandafter\def\csname podoblast:#2\endcsname{#3}
\expandafter\ifx\csname podoblast:#1\endcsname\relax
\expandafter\def\csname podoblast:#1\endcsname{#3}
\else
\expandafter\def\csname podoblast:#1\endcsname{}
\fi
}
\input msr_podoblasti.tex

\def\msr@tema{}
\def\tema#1{\expandafter\ifx \csname podoblast:#1\endcsname\relax \MsrError{msr}{Spatne vyplnene jmeno podoblasti (argument prikazu tema)}\fi
\oblast{\csname podoblast:#1\endcsname}}

