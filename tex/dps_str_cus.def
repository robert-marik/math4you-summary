\def\triedTooMuch{"Zkou\u0161íte tuto otázku opakovan\u011B neúsp\u011B\u0161n\u011B. P\u0159idávám t\u0159i trestné body."}
\def\congratFinished{"Dokon\u010Deno"
        +((nMissed==0) ? " bez jediné chyby!"
        : ", ale b\u011Bhem \u0159e\u0161ení jste se dopustili " + ( (nMissed==1) ? "jedné chyby!" : ""+ nMissed +" chyb!"))}
\def\regretPleased{(( nMissed > n )
        ? "I regret to report that you did not pass the test because you missed too many questions."
        : "I am pleased to report that you passed the test!")}
\def\reportPenaltyPoints{( (nPenaltyPoints>0) ? "Po\u010Det trestných bod\u016F za hádání je " + nPenaltyPoints +".":"")}
\def\finalPenaltyScore{( (nPenaltyPoints>0) ? "Sou\u010Det po\u010Dtu chybných odpov\u011Bdí a trestných bod\u016F je " + nTotalPenaltyPoints + ". ":"")}
