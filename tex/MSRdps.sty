    // see if checked.
    var f = this.getField("ckbxQ."+fieldname);
    if ( (f != null) && (f.isBoxChecked(0)) ) { // right
        clearRedCrosses ();
        //this.resetForm(["puzzle."+fieldname]);
        var ff=this.getField("puzzle."+fieldname);
        if (ff!=null)
        {
          ff.hidden=true;
        } 
        event.target.textColor = ["RGB", 0, 0.6, 0];
        f.strokeColor = ["RGB", 0, 0.6, 0];
        f.readonly = true;
        event.target.readonly=true;
        checkForFinished(\dspassing,klic);
    } else { // wrong
        if ( activeQuestion != "" ) var h = this.getField(activeQuestion);
        if ( (activeQuestion=="") || (h.readonly) ) { // active question already answered
            event.target.value = "Off";
            str = \chooseQ;
            var g = this.getField("report.1");
            if (g!= null)
            {
              g.value = str;
              var to = app.setTimeOut("clearMessages()", 2000);
            }
            else {app.alert(str,3);}
        } else {
            event.target.style = style.cr;
            event.target.textColor = color.red;
            event.target.readonly = true;
            ++nMissed;
            if ( typeof missesByQuestion[activeQuestion] !="number" )
                missesByQuestion[activeQuestion] = 1;
            else
                missesByQuestion[activeQuestion] += 1;
            if (missesByQuestion[activeQuestion] > \dsthreshold) {
                str = \triedTooMuch;
                nPenaltyPoints += \dspenaltypoints;
                missesByQuestion[activeQuestion] = 0;
                clearRedCrosses ();
                var f = this.getField("report.1");
                if (f!=null)
                {
                  f.value = str;
                  var to = app.setTimeOut("clearMessages()", 2000)
                }
                else
                {app.alert (str,3);}
            }
        }
    }
}
function clearMessages()
{
  var f = this.getField("report.1");
  if (f!=null)
  {
    f.value = "";
  }
  var f = this.getField("report.2");
  if (f!=null)
  {
    f.value = "";
  }
}

function clearRedCrosses ()
{
    var g = this.getField("ckbxA");
    h = g.getArray();
    for ( i=0; i < h.length; i++) {
        if ( h[i].style == style.cr) 
        { 
          h[i].checkThisBox(0,false);
          h[i].readonly=false; 
          jmeno=h[i].name.substr(6); 
          odp=this.getField("odpoved."+jmeno)
          if (odp != null) odp.readonly=false;
        }
        h[i].style = style.ch;
    }
 }
function checkForFinished(n,klic)
{
  if (spusteno == 0)
  {
    spusteno=1;
    if (jmenoOCGs["tajenka"]!=null) {odkryjocg("tajenka");}
  }
    var f = this.getField("ckbxQ");
    var g = f.getArray();
    var anyEmpty = false;
    for ( var i=0; i < g.length; i++) {
        if ( (g[i].name != "puzzle.space") && (g[i].readonly == false) ) {
            anyEmpty = true;
            break;
        }
    }
    nPenaltyPoints = 0;
    var nTotalPenaltyPoints=nMissed + nPenaltyPoints;
    if ( !anyEmpty ) {
        hotovo=1;
        var f = this.getField("ckbxA");
        if (f!=null) {f.readonly=true;}
        var f = this.getField("odpoved");
        if (f!=null) {f.readonly=true;}
        stra = "\u0158e\u0161en\u00ed: "+klic;
        str = PocetChybMsg(nMissed);
        var f = this.getField("report.1");
        if (f!=null) {f.value = stra;} else {str = str + "\n\n" + stra;}
        var f = this.getField("report.2");
        if (f!=null) {f.value = str;}
        var P= (2* KonstPocetOdpovedi - KonstPocetOtazek + 1 ) * KonstPocetOdpovedi /2;
        var znamka = "5";
        if (nMissed <= 0.6 * ( P - KonstPocetOdpovedi )) znamka="4";
        if (nMissed <= 0.4 * ( P - KonstPocetOdpovedi )) znamka="3";
        if (nMissed <= 0.25 * ( P - KonstPocetOdpovedi )) znamka="2";
        if (nMissed <= 0.1 * ( P - KonstPocetOdpovedi )) znamka="1";
        if (nMissed <= 0.005 * ( P - KonstPocetOdpovedi )) znamka="0";
        odkryjocg("oblicej"+znamka);
        odkryjocg("hotovo");
        \MsrBublinaZpozdenaB
    }
    this.dirty=false;
}

function finalRating(n) {
    var aPenaltyScale = new Array( \aPenaltyScale\space);
    var aPenaltyMsgs = new Array( \aPenaltyMsgs\space);
    for ( var i=0; i<aPenaltyScale.length; i++)
        if ( (n > aPenaltyScale[i][0]) && (n <= aPenaltyScale[i][1]) )
            return aPenaltyMsgs[i];
}

