\def\sablona{\@ifstar\sablona@Star\sablona@NoStar}
\def\sablona@Star{\let\msr@obalka@odpovedi\ensuremath\sablona@Both}
\def\sablona@NoStar{\let\msr@obalka@odpovedi\relax\sablona@Both}

\let\ObalkaOdpovedi\relax
\def\sablona@Both{\ifx\ObalkaOdpovedi\relax\else\let\msr@obalka@odpovedi\ObalkaOdpovedi\fi\@ifnextchar[\@sablona{\@sablona[]}}

\long\def\@sablona[#1]#2#3{%
  \def\msr@pocetsloupcu{2}%
\def\msr@sablona{A}%
\def\msr@multicol{1}%
\msr@minipage = 0pt\relax
\def\msr@pts{1}%
\def\msr@pt@varianta{1}%
\def\@msr@top{}%
\@mi@forcemanswersfalse
\let\opt@intervaly\relax
\rowsep{4pt}
\setkeys{template}{#1}%
\def\mfu@otazka{#2}%
\ifx\@optimage\empty \else
\def\msr@pocetsloupcu{1}
\expandafter\def\expandafter\@msr@top\expandafter{\mfu@otazka}
\def\mfu@otazka{\kern 0 pt\MYQincludegraphics{\@optimage}}
\ifdim\msr@minipage<1pt
\msr@minipage=0.5\linewidth\relax
\fi
\fi
\csname @sablona\msr@sablona\endcsname{\mfu@otazka}{#3}
\let\@optimage\empty
% some operations to typeset #2
}

\def\jedna{1}
 
\long\def\@sablonaA#1#2{
    \begin{blok}
      \msr@extraspace
      %\ifx\msr@pts0\else %\PTsHook{($\eqPTs^{\text{pts}}$)}
      \PTs{\msr@pts}%\fi
      \opt@intervaly
      \ifx\@msr@top\empty \else \@msr@top\par\fi
      \ifx\msr@multicol\jedna\else\begin{multicols}{\msr@multicol}\fi
        \ifdim\msr@minipage>1pt \begin{minipage}[t]{\msr@minipage}\fi
          #1
          \ifdim\msr@minipage>1pt \end{minipage}\hskip 1em \hfill\begin{minipage}[t]{\linewidth-\msr@minipage-1em}\else \par\fi        
          {\sloppy \pocetsloupcu{\msr@pocetsloupcu}\expandafter\odpovedi\expandafter[\expandafter\msr@pt@varianta\expandafter]\expandafter{#2}\par}%
          \ifdim\msr@minipage>1pt \end{minipage}\fi        
        \ifx\msr@multicol\jedna\else\end{multicols}\fi
    \end{blok}
    
}

\long\def\@sablonaB#1#2{
    \begin{blok}
      %\ifx\msr@pts0\else %\PTsHook{($\eqPTs^{\text{pts}}$)}
      \msr@extraspace
      \opt@intervaly
      \ifx\@msr@top\empty \else \@msr@top\par\fi
      \ifx\msr@multicol\jedna\else\begin{multicols}{\msr@multicol}\fi
        \begin{minipage}[t]{.3\linewidth}
          #1
        \end{minipage}\hskip 1em \hfill\begin{minipage}[t]{0.6\linewidth}
          {\sloppy \pocetsloupcu{2}\expandafter\odpovedi\expandafter[\expandafter\msr@pt@varianta\expandafter]\expandafter{#2}\par}%
        \end{minipage}
        \ifx\msr@multicol\jedna\else\end{multicols}\fi
    \end{blok}
    
}


\long\def\@sablonaC#1#2{
    \begin{blok}
      %\ifx\msr@pts0\else %\PTsHook{($\eqPTs^{\text{pts}}$)}
      \PTs{\msr@pts}%\fi
      \msr@extraspace
      \opt@intervaly
      \ifx\msr@multicol\jedna\else\begin{multicols}{\msr@multicol}\fi
        \ifdim\msr@minipage>1pt \begin{minipage}[t]{\msr@minipage}\fi
          \ifx\@msr@top\empty \else \@msr@top\par\fi
          \ifdim\msr@minipage>1pt \end{minipage}\hskip 1em \hfill\begin{minipage}[t]{\linewidth-\msr@minipage-1em}\else \par\fi        
          #1
          \ifdim\msr@minipage>1pt \end{minipage}\fi        
        \ifx\msr@multicol\jedna\else\end{multicols}\fi
          {\sloppy \pocetsloupcu{\msr@pocetsloupcu}\expandafter\odpovedi\expandafter[\expandafter\msr@pt@varianta\expandafter]\expandafter{#2}\par}%
    \end{blok}
    
}


